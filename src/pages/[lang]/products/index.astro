---
import Layout from '../../../layouts/Layout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { t, lp, staticPaths, type Locale } from '../../../i18n/index';
import { coolers, fans } from '../../../data/products';

export function getStaticPaths() { return staticPaths(); }

const { lang } = Astro.params;
const locale = lang as Locale;

const pageTitle = locale === 'zh'
  ? 'AirMax 產品系列 — 冷風機 ＆ 工業風扇'
  : 'AirMax Product Range — Air Coolers & Industrial Fans';
const pageDesc = locale === 'zh'
  ? '瀏覽 AirMax 全系列冷風機及工業風扇，涵蓋家居至工業用途，WhatsApp 即時查詢。'
  : 'Browse the full AirMax range of air coolers and industrial fans for home, commercial and industrial use.';
---

<Layout
  locale={locale}
  title={pageTitle}
  description={pageDesc}
  canonicalPath={lp(locale, '/products')}
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-14 max-w-xl reveal">
      <h1 class="text-4xl font-semibold tracking-tight text-slate-900 lg:text-5xl">
        {t(locale, 'range.title')}
      </h1>
      <p class="mt-4 text-lg text-slate-500 leading-relaxed">
        {t(locale, 'range.sub')}
      </p>
    </div>

    <!-- Air Coolers -->
    <section class="mb-16" aria-labelledby="coolers-heading">
      <div class="mb-6 flex items-baseline justify-between reveal">
        <h2 id="coolers-heading" class="text-xl font-semibold text-slate-900">
          {t(locale, 'range.coolers')}
          <span class="ml-2 text-base font-normal text-slate-400">({coolers.length})</span>
        </h2>
      </div>
      <div class="reveal-stagger grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {coolers.map((product) => (
          <ProductCard product={product} locale={locale} />
        ))}
      </div>
    </section>

    <!-- Divider -->
    <div class="mb-14 border-t border-slate-100"></div>

    <!-- Industrial Fans -->
    <section aria-labelledby="fans-heading">
      <div class="mb-6 flex items-baseline justify-between reveal">
        <h2 id="fans-heading" class="text-xl font-semibold text-slate-900">
          {t(locale, 'range.fans')}
          <span class="ml-2 text-base font-normal text-slate-400">({fans.length})</span>
        </h2>
      </div>
      <div class="reveal-stagger grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {fans.map((product) => (
          <ProductCard product={product} locale={locale} />
        ))}
      </div>
    </section>

  </div>
</Layout>
