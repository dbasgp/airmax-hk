---
import Layout from '../../../layouts/Layout.astro';
import { t, lp, type Locale } from '../../../i18n/index';
import { products, waLink, formatHkd, type Product } from '../../../data/products';

export function getStaticPaths() {
  return ['zh', 'en'].flatMap((lang) =>
    products.map((product) => ({
      params: { lang, id: product.id },
      props: { product },
    }))
  );
}

interface Props { product: Product; }
const { lang } = Astro.params;
const locale = lang as Locale;
const { product } = Astro.props;

const { name, sku, airflow, coverage, priceHkd, highlights, image, enquiry, category } = product;
const imgErr = locale === 'zh' ? '圖片即將上線' : 'Image coming soon';
const displayName = name[locale];
const waHref = waLink(enquiry[locale]);

const pageTitle = locale === 'zh'
  ? `${displayName} — AirMax.hk`
  : `${displayName} — AirMax.hk`;
const pageDesc = locale === 'zh'
  ? `${displayName}${airflow ? `，風量 ${airflow}` : ''}${coverage ? `，適用面積 ${coverage}` : ''}。WhatsApp 查詢即時回覆。`
  : `${displayName}${airflow ? `, ${airflow} airflow` : ''}${coverage ? `, covers ${coverage}` : ''}. Enquire on WhatsApp.`;
---

<Layout
  locale={locale}
  title={pageTitle}
  description={pageDesc}
  canonicalPath={lp(locale, `/products/${product.id}`)}
  ogImage={image}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">

    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 text-sm text-slate-400 reveal" aria-label="Breadcrumb">
      <a href={lp(locale)} class="hover:text-slate-600 transition-colors">
        {t(locale, 'nav.home')}
      </a>
      <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <a href={lp(locale, '/products')} class="hover:text-slate-600 transition-colors">
        {t(locale, 'nav.products')}
      </a>
      <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-slate-600 truncate max-w-[180px]">{displayName}</span>
    </nav>

    <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">

      <!-- Image -->
      <div class="reveal">
        <div class="aspect-square overflow-hidden rounded-2xl border border-slate-100 bg-slate-50 flex items-center justify-center p-8">
          <img
            src={image}
            alt={displayName}
            class="h-full w-full object-contain"
            loading="eager"
            decoding="async"
            onerror={`this.onerror=null;this.alt='${imgErr}';this.style.opacity='.2'`}
          />
        </div>
      </div>

      <!-- Info -->
      <div class="reveal flex flex-col gap-6">

        <!-- Category badge -->
        <div>
          <span class="spec-badge">
            {category === 'cooler'
              ? (locale === 'zh' ? '冷風機' : 'Air Cooler')
              : (locale === 'zh' ? '工業風扇' : 'Industrial Fan')}
          </span>
        </div>

        <div>
          <h1 class="text-3xl font-medium tracking-tight text-slate-900 sm:text-4xl">
            {displayName}
          </h1>
          <p class="mt-1 text-sm text-slate-400">{t(locale, 'detail.sku')}: {sku}</p>
        </div>

        <!-- Specs table -->
        <div class="rounded-xl border border-slate-100 divide-y divide-slate-100">
          {airflow && (
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-sm text-slate-500">{t(locale, 'detail.airflow')}</span>
              <span class="text-sm font-medium text-slate-900">{airflow}</span>
            </div>
          )}
          {coverage && (
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-sm text-slate-500">{t(locale, 'detail.coverage')}</span>
              <span class="text-sm font-medium text-slate-900">{coverage}</span>
            </div>
          )}
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-sm text-slate-500">{t(locale, 'detail.price')}</span>
            <span class="text-sm font-medium text-slate-900">
              {priceHkd !== null ? formatHkd(priceHkd) : t(locale, 'detail.price.enquire')}
            </span>
          </div>
        </div>

        <!-- Highlights -->
        {highlights.length > 0 && (
          <div>
            <h2 class="mb-3 text-sm font-semibold text-slate-700">{t(locale, 'detail.highlights')}</h2>
            <ul class="space-y-2">
              {highlights.map((h) => (
                <li class="flex items-start gap-2 text-sm text-slate-600">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  {h[locale]}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- WhatsApp CTA -->
        <div class="pt-2">
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary w-full justify-center py-3.5 text-base"
          >
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            {t(locale, 'detail.enquire')}
          </a>
          <a href={lp(locale, '/products')} class="btn-ghost mt-3 w-full justify-center">
            ← {t(locale, 'detail.back')}
          </a>
        </div>

      </div>
    </div>
  </div>
</Layout>
