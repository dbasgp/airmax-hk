---
import Layout from '../../../layouts/Layout.astro';
import { t, lp, type Locale } from '../../../i18n/index';
import { products, waLink, formatHkd, type Product } from '../../../data/products';

export function getStaticPaths() {
  return ['zh', 'en'].flatMap((lang) =>
    products.map((product) => ({
      params: { lang, id: product.id },
      props: { product },
    }))
  );
}

interface Props { product: Product; }
const { lang } = Astro.params;
const locale = lang as Locale;
const { product } = Astro.props;

const { name, sku, airflow, coverage, priceHkd, highlights, image, enquiry, category } = product;
const imgErr = locale === 'zh' ? '圖片即將上線' : 'Image coming soon';
const displayName = name[locale];
const waHref = waLink(enquiry[locale]);

const sqftNum = coverage ? parseInt(coverage) : 0;
const sqftFormatted = sqftNum ? sqftNum.toLocaleString('en-HK') : '';
const isFan = category === 'fan';

const pageTitle = `${displayName} — AirMax.hk`;
const pageDesc = locale === 'zh'
  ? `${displayName}${sqftNum ? `，適冷約 ${sqftFormatted} 呎` : ''}${airflow ? `，風量 ${airflow}` : ''}。WhatsApp 查詢即時回覆。`
  : `${displayName}${sqftNum ? `, cools ~${sqftFormatted} sqft` : ''}${airflow ? `, ${airflow} airflow` : ''}. Enquire on WhatsApp.`;
---

<Layout
  locale={locale}
  title={pageTitle}
  description={pageDesc}
  canonicalPath={lp(locale, `/products/${product.id}`)}
  ogImage={image}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">

    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 text-sm text-slate-400 reveal" aria-label="Breadcrumb">
      <a href={lp(locale)} class="hover:text-slate-600 transition-colors">{t(locale, 'nav.home')}</a>
      <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <a href={lp(locale, '/products')} class="hover:text-slate-600 transition-colors">{t(locale, 'nav.products')}</a>
      <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-slate-600 truncate max-w-[180px]">{displayName}</span>
    </nav>

    <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">

      <!-- Image -->
      <div class="reveal">
        <div class="aspect-square overflow-hidden rounded-2xl border border-slate-100 bg-slate-50 flex items-center justify-center p-8">
          <img
            src={image}
            alt={displayName}
            class="h-full w-full object-contain"
            loading="eager"
            decoding="async"
            onerror={`this.onerror=null;this.alt='${imgErr}';this.style.opacity='.2'`}
          />
        </div>
      </div>

      <!-- Info -->
      <div class="reveal flex flex-col gap-6">

        <!-- Category badge -->
        <div>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-sky-50 px-3 py-1 text-xs font-medium text-sky-600">
            {category === 'cooler' ? (
              <>
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/>
                </svg>
                {locale === 'zh' ? '冷風機' : 'Air Cooler'}
              </>
            ) : (
              <>
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5c-1.505 2.916-4.5 3-4.5 3S9 10.5 12 10.5c1.505-2.916 4.5-3 4.5-3S15 4.5 12 4.5zM12 19.5c1.505-2.916 4.5-3 4.5-3S15 13.5 12 13.5c-1.505 2.916-4.5 3-4.5 3S9 19.5 12 19.5zM4.5 12c2.916 1.505 3 4.5 3 4.5S10.5 15 10.5 12c-2.916-1.505-3-4.5-3-4.5S4.5 9 4.5 12zM19.5 12c-2.916 1.505-3 4.5-3 4.5S13.5 15 13.5 12c2.916-1.505 3-4.5 3-4.5S19.5 9 19.5 12z"/>
                </svg>
                {locale === 'zh' ? '工業風扇' : 'Industrial Fan'}
              </>
            )}
          </span>
        </div>

        <!-- Name + SKU -->
        <div>
          <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
            {displayName}
          </h1>
          <p class="mt-1.5 text-sm text-slate-400">{t(locale, 'detail.sku')}: {sku}</p>
        </div>

        <!-- Coverage hero stat (for coolers with coverage) -->
        {sqftNum > 0 && (
          <div class="rounded-2xl bg-sky-50 px-5 py-4 flex items-center gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-sky-500">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
              </svg>
            </div>
            <div>
              <div class="text-2xl font-bold text-sky-600 leading-none">
                {sqftFormatted} {locale === 'zh' ? '呎' : 'sqft'}
              </div>
              <div class="mt-0.5 text-sm text-sky-500">
                {locale === 'zh' ? '推薦適冷面積' : 'Recommended coverage area'}
              </div>
            </div>
          </div>
        )}

        <!-- Specs table -->
        <div class="divide-y divide-slate-100 rounded-xl border border-slate-100 overflow-hidden">
          {airflow && (
            <div class="flex items-center justify-between px-4 py-3 bg-white">
              <span class="text-sm text-slate-500 flex items-center gap-2">
                <svg class="h-4 w-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
                </svg>
                {locale === 'zh' ? '風量（技術規格）' : 'Airflow (technical)'}
              </span>
              <span class="text-sm font-medium text-slate-900">{airflow}</span>
            </div>
          )}
          <div class="flex items-center justify-between px-4 py-3 bg-white">
            <span class="text-sm text-slate-500">{t(locale, 'detail.price')}</span>
            <span class="text-sm font-medium text-slate-900">
              {priceHkd !== null ? formatHkd(priceHkd) : t(locale, 'detail.price.enquire')}
            </span>
          </div>
        </div>

        <!-- Highlights -->
        {highlights.length > 0 && (
          <div>
            <h2 class="mb-3 text-sm font-semibold text-slate-700">{t(locale, 'detail.highlights')}</h2>
            <ul class="space-y-2.5">
              {highlights.map((h) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-600">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
                  </svg>
                  {h[locale]}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- WhatsApp CTA -->
        <div class="pt-2 space-y-3">
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary w-full justify-center py-3.5 text-base"
          >
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            {t(locale, 'detail.enquire')}
          </a>
          <a href={lp(locale, '/products')} class="btn-ghost w-full justify-center text-sm">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
            </svg>
            {t(locale, 'detail.back')}
          </a>
        </div>

      </div>
    </div>
  </div>
</Layout>
