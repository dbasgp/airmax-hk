---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import { t, lp, staticPaths, type Locale } from '../../i18n/index';
import { products, coolers, contact, waLink } from '../../data/products';

export function getStaticPaths() { return staticPaths(); }

const { lang } = Astro.params;
const locale = lang as Locale;

const featured = coolers.slice(0, 3);

const pageTitle = locale === 'zh'
  ? 'AirMax.hk — 香港冷風機專家'
  : 'AirMax.hk — Air Cooler Specialists in Hong Kong';
const pageDesc = locale === 'zh'
  ? '香港專業冷風機品牌，涵蓋家居、商業及工業用途。WhatsApp 即時查詢。'
  : 'Professional air coolers for Hong Kong — home, commercial and industrial. Enquire on WhatsApp.';

const heroWa = waLink(
  locale === 'zh'
    ? '你好 AirMax，我想查詢你們的冷風機系列。'
    : 'Hi AirMax, I\'d like to know more about your air cooler range.'
);
---

<Layout
  locale={locale}
  title={pageTitle}
  description={pageDesc}
  canonicalPath={lp(locale)}
>

  <!-- ── HERO ── -->
  <section class="relative overflow-hidden bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="max-w-2xl">
        <p class="hero-line section-label">{t(locale, 'range.label')}</p>
        <h1 class="hero-line text-5xl font-medium tracking-tight text-slate-900 sm:text-6xl lg:text-7xl">
          {t(locale, 'hero.headline')}
        </h1>
        <p class="hero-line mt-6 text-lg text-slate-500 leading-relaxed max-w-xl">
          {t(locale, 'hero.sub')}
        </p>
        <div class="hero-line mt-8 flex flex-wrap gap-3">
          <a href={lp(locale, '/products')} class="btn-primary">
            {t(locale, 'hero.cta.range')}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
          <a href={heroWa} target="_blank" rel="noopener noreferrer" class="btn-secondary">
            <svg class="h-4 w-4 text-sky-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            {t(locale, 'hero.cta.whatsapp')}
          </a>
        </div>

        <!-- Stats strip -->
        <div class="hero-line mt-10 flex flex-wrap gap-8 border-t border-slate-100 pt-6">
          <div>
            <div class="text-2xl font-semibold text-slate-900">{products.length}+</div>
            <div class="text-xs text-slate-500 mt-0.5">{locale === 'zh' ? '產品型號' : 'Models'}</div>
          </div>
          <div>
            <div class="text-2xl font-semibold text-slate-900">1,200</div>
            <div class="text-xs text-slate-500 mt-0.5">{locale === 'zh' ? '最大適冷面積（呎）' : 'Max coverage (sqft)'}</div>
          </div>
          <div>
            <div class="text-2xl font-semibold text-slate-900">80%</div>
            <div class="text-xs text-slate-500 mt-0.5">{locale === 'zh' ? '較冷氣慳電' : 'vs A/C energy saving'}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Decorative background gradient -->
    <div
      class="pointer-events-none absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l from-sky-50 to-transparent"
      aria-hidden="true"
    ></div>
  </section>

  <!-- ── FEATURED PRODUCTS ── -->
  <section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="section-header reveal">
        <p class="section-label">{t(locale, 'nav.products')}</p>
        <h2 class="section-title">{locale === 'zh' ? '精選產品' : 'Featured products'}</h2>
        <p class="section-subtitle">{t(locale, 'range.sub')}</p>
      </div>

      <div class="reveal grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((product) => (
          <ProductCard product={product} locale={locale} />
        ))}
      </div>

      <div class="mt-10 reveal">
        <a href={lp(locale, '/products')} class="btn-secondary">
          {t(locale, 'hero.cta.range')}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── WHY AIRMAX (preview) ── -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="section-header reveal">
        <p class="section-label">{t(locale, 'why.label')}</p>
        <h2 class="section-title">{t(locale, 'why.title')}</h2>
        <p class="section-subtitle">{t(locale, 'why.sub')}</p>
      </div>
      <FeatureGrid locale={locale} />
      <div class="mt-10 reveal">
        <a href={lp(locale, '/why-airmax')} class="btn-secondary">
          {locale === 'zh' ? '了解更多' : 'Learn more'}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── CTA BAND ── -->
  <section class="bg-sky-500 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 reveal">
      <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-2xl font-medium text-white">
            {locale === 'zh' ? '準備好了嗎？' : 'Ready to enquire?'}
          </h2>
          <p class="mt-1 text-sky-100">
            {locale === 'zh'
              ? '我們會即時透過 WhatsApp 回覆您的查詢。'
              : 'We reply on WhatsApp straight away.'}
          </p>
        </div>
        <a
          href={`https://wa.me/${contact.whatsapp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex shrink-0 items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-medium text-sky-600 transition-colors hover:bg-sky-50"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          {t(locale, 'why.cta')}
        </a>
      </div>
    </div>
  </section>

</Layout>
