---
import Layout from '../../layouts/Layout.astro';
import EnquiryForm from '../../components/EnquiryForm.astro';
import { t, lp, staticPaths, type Locale } from '../../i18n/index';
import { contact } from '../../data/products';

export function getStaticPaths() { return staticPaths(); }

const { lang } = Astro.params;
const locale = lang as Locale;

const pageTitle = locale === 'zh'
  ? 'WhatsApp 查詢 — AirMax.hk'
  : 'Enquiry — AirMax.hk';
const pageDesc = locale === 'zh'
  ? '透過 WhatsApp 查詢 AirMax 冷風機，即時獲得報價及送貨資訊。'
  : 'Enquire about AirMax air coolers on WhatsApp — get pricing and delivery information straight away.';
---

<Layout
  locale={locale}
  title={pageTitle}
  description={pageDesc}
  canonicalPath={lp(locale, '/enquiry')}
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16">

      <!-- Left: info -->
      <div class="reveal">
        <p class="section-label">{t(locale, 'enquiry.label')}</p>
        <h1 class="section-title">{t(locale, 'enquiry.title')}</h1>
        <p class="mt-4 text-slate-500">{t(locale, 'enquiry.sub')}</p>

        <!-- Direct contact options -->
        <div class="mt-10 space-y-4">
          <h2 class="text-sm font-semibold text-slate-700">{t(locale, 'enquiry.direct')}</h2>

          <a
            href={`https://wa.me/${contact.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 rounded-xl border border-slate-100 bg-white p-4 transition-shadow hover:shadow-sm"
          >
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-green-50">
              <svg class="h-5 w-5 text-green-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-900">{t(locale, 'about.whatsapp')}</div>
              <div class="text-sm text-slate-500">{contact.whatsappDisplay}</div>
            </div>
            <svg class="ml-auto h-4 w-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>

          <a
            href={`mailto:${contact.email}`}
            class="flex items-center gap-4 rounded-xl border border-slate-100 bg-white p-4 transition-shadow hover:shadow-sm"
          >
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-sky-50">
              <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-900">{t(locale, 'about.email')}</div>
              <div class="text-sm text-slate-500">{contact.email}</div>
            </div>
            <svg class="ml-auto h-4 w-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="reveal">
        <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm lg:p-8">
          <EnquiryForm locale={locale} />
        </div>
      </div>

    </div>
  </div>
</Layout>
