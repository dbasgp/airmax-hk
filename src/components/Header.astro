---
import { t, lp, altPath, type Locale } from '../i18n/index';
import { contact } from '../data/products';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const alt = altPath(locale, currentPath);
const altLabel = t(locale, 'nav.lang');

const nav = [
  { key: 'nav.home' as const,     href: lp(locale) },
  { key: 'nav.products' as const, href: lp(locale, '/products') },
  { key: 'nav.why' as const,      href: lp(locale, '/why-airmax') },
  { key: 'nav.enquiry' as const,  href: lp(locale, '/enquiry') },
  { key: 'nav.about' as const,    href: lp(locale, '/about') },
];
---

<header class="sticky top-0 z-50 border-b border-slate-100 bg-white/90 backdrop-blur-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">

    <!-- Logo -->
    <a href={lp(locale)} class="flex items-center gap-2 group" aria-label="AirMax Home">
      <span class="text-xl font-semibold tracking-tight text-slate-900 group-hover:text-sky-500 transition-colors">
        Air<span class="text-sky-500 group-hover:text-slate-900 transition-colors">Max</span>
      </span>
      <span class="hidden text-xs text-slate-400 sm:inline">.hk</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-6 lg:flex" aria-label="Main navigation">
      {nav.map(({ key, href }) => (
        <a
          href={href}
          class={`text-sm transition-colors hover:text-sky-500 ${
            currentPath === href ? 'font-medium text-sky-500' : 'text-slate-600'
          }`}
        >
          {t(locale, key)}
        </a>
      ))}
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-3">
      <!-- Lang switcher -->
      <a
        href={alt}
        class="hidden text-sm font-medium text-slate-500 transition-colors hover:text-slate-900 sm:inline"
        aria-label="Switch language"
      >
        {altLabel}
      </a>

      <!-- WhatsApp CTA -->
      <a
        href={`https://wa.me/${contact.whatsapp}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-xs sm:text-sm"
        aria-label="WhatsApp"
      >
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        <span class="hidden sm:inline">{t(locale, 'nav.why') === 'Why AirMax' ? 'WhatsApp' : 'WhatsApp'}</span>
      </a>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        class="rounded-md p-2 text-slate-600 hover:bg-slate-100 lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-100 bg-white px-4 pb-4 lg:hidden"
    aria-label="Mobile navigation"
  >
    <nav class="flex flex-col gap-1 pt-2">
      {nav.map(({ key, href }) => (
        <a
          href={href}
          class={`rounded-md px-3 py-2 text-sm transition-colors hover:bg-slate-50 hover:text-sky-500 ${
            currentPath === href ? 'font-medium text-sky-500' : 'text-slate-700'
          }`}
        >
          {t(locale, key)}
        </a>
      ))}
      <a
        href={alt}
        class="rounded-md px-3 py-2 text-sm text-slate-500 transition-colors hover:bg-slate-50 hover:text-slate-900"
      >
        {altLabel}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
