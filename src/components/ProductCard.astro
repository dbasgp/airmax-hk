---
import { t, lp, type Locale } from '../i18n/index';
import { waLink, formatHkd, type Product } from '../data/products';

interface Props {
  product: Product;
  locale: Locale;
}
const { product, locale } = Astro.props;
const { name, airflow, coverage, priceHkd, highlights, image, enquiry, id, category } = product;

const waHref = waLink(enquiry[locale]);
const detailHref = lp(locale, `/products/${id}`);
const displayName = name[locale];
const highlight = highlights[0]?.[locale] ?? '';

// Parse coverage number for display
const sqftNum = coverage ? parseInt(coverage) : 0;
const sqftFormatted = sqftNum ? sqftNum.toLocaleString('en-HK') : '';

// What to display as the primary "size" spec
const isFan = category === 'fan';
const hasCoverage = sqftNum > 0;
---

<article class="stagger-item group flex flex-col rounded-2xl bg-white border border-slate-100 overflow-hidden transition-all duration-200 hover:shadow-[0_4px_24px_rgba(14,165,233,0.10)] hover:-translate-y-0.5">

  <!-- Image -->
  <a href={detailHref} class="block overflow-hidden bg-slate-50" aria-label={displayName} tabindex="-1">
    <div class="aspect-[4/3] overflow-hidden">
      <img
        src={image}
        alt={displayName}
        class="h-full w-full object-contain p-5 transition-transform duration-300 group-hover:scale-[1.04]"
        loading="lazy"
        decoding="async"
        onerror="this.parentElement.innerHTML='<div class=\'flex h-full items-center justify-center text-slate-200\'><svg xmlns=\'http://www.w3.org/2000/svg\' class=\'h-10 w-10\' fill=\'none\' viewBox=\'0 0 24 24\' stroke=\'currentColor\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1\' d=\'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z\'/></svg></div>'"
      />
    </div>
  </a>

  <!-- Body -->
  <div class="flex flex-1 flex-col p-5 gap-3">

    <!-- Name + primary coverage stat -->
    <div class="flex-1">
      <a href={detailHref} class="block text-sm font-semibold text-slate-900 hover:text-sky-500 transition-colors leading-snug">
        {displayName}
      </a>

      <!-- Coverage — the number customers care about -->
      <div class="mt-2.5 flex items-center gap-2">
        {hasCoverage ? (
          <>
            <!-- Expand/area icon -->
            <svg class="h-4 w-4 shrink-0 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
            </svg>
            <span class="text-sm font-medium text-sky-600">
              {locale === 'zh'
                ? `適冷約 ${sqftFormatted} 呎`
                : `Cools ~${sqftFormatted} sqft`}
            </span>
          </>
        ) : isFan ? (
          <>
            <!-- Wind/fan icon -->
            <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5c-1.505 2.916-4.5 3-4.5 3S9 10.5 12 10.5c1.505-2.916 4.5-3 4.5-3S15 4.5 12 4.5zM12 19.5c1.505-2.916 4.5-3 4.5-3S15 13.5 12 13.5c-1.505 2.916-4.5 3-4.5 3S9 19.5 12 19.5zM4.5 12c2.916 1.505 3 4.5 3 4.5S10.5 15 10.5 12c-2.916-1.505-3-4.5-3-4.5S4.5 9 4.5 12zM19.5 12c-2.916 1.505-3 4.5-3 4.5S13.5 15 13.5 12c2.916-1.505 3-4.5 3-4.5S19.5 9 19.5 12z"/>
            </svg>
            <span class="text-sm font-medium text-slate-500">
              {locale === 'zh' ? t(locale, 'range.fan.desc') : t(locale, 'range.fan.desc')}
            </span>
          </>
        ) : (
          <>
            <!-- Industrial icon -->
            <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/>
            </svg>
            <span class="text-sm font-medium text-slate-500">
              {t(locale, 'range.industrial')}
            </span>
          </>
        )}
      </div>

      <!-- Highlight subtitle -->
      {highlight && (
        <p class="mt-1.5 text-xs text-slate-400 line-clamp-2 leading-relaxed">{highlight}</p>
      )}
    </div>

    <!-- Price + CTA -->
    <div class="flex items-center justify-between gap-3 pt-3 border-t border-slate-100">
      <div>
        {priceHkd !== null ? (
          <span class="text-base font-semibold text-slate-900">
            HK${priceHkd.toLocaleString('en-HK')}
          </span>
        ) : (
          <span class="text-xs text-slate-400 font-medium">{t(locale, 'range.price.enquire')}</span>
        )}
      </div>
      <a
        href={waHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex shrink-0 items-center gap-1.5 rounded-full bg-sky-500 px-4 py-2 text-xs font-medium text-white transition-colors hover:bg-sky-600 active:scale-[0.97]"
        aria-label={`WhatsApp enquiry for ${displayName}`}
      >
        <!-- WhatsApp icon -->
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        {t(locale, 'range.cta')}
      </a>
    </div>
  </div>
</article>
