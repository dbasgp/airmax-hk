---
import { t, lp, type Locale } from '../i18n/index';
import { waLink, formatHkd, type Product } from '../data/products';

interface Props {
  product: Product;
  locale: Locale;
}
const { product, locale } = Astro.props;
const { name, airflow, coverage, priceHkd, highlights, image, enquiry, id } = product;

const waHref = waLink(enquiry[locale]);
const detailHref = lp(locale, `/products/${id}`);
const displayName = name[locale];
const highlight = highlights[0]?.[locale] ?? '';
---

<article class="stagger-item group flex flex-col rounded-2xl border border-slate-100 bg-white overflow-hidden transition-shadow hover:shadow-md">

  <!-- Image -->
  <a href={detailHref} class="block aspect-square overflow-hidden bg-slate-50" aria-label={displayName} tabindex="-1">
    <img
      src={image}
      alt={displayName}
      class="h-full w-full object-contain p-6 transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
      decoding="async"
      onerror="this.parentElement.innerHTML='<div class=\'flex h-full items-center justify-center text-slate-300\'><svg xmlns=\'http://www.w3.org/2000/svg\' class=\'h-12 w-12\' fill=\'none\' viewBox=\'0 0 24 24\' stroke=\'currentColor\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1\' d=\'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z\'/></svg></div>'"
    />
  </a>

  <!-- Body -->
  <div class="flex flex-1 flex-col gap-3 p-5">

    <div>
      <a href={detailHref} class="text-sm font-medium text-slate-900 hover:text-sky-500 transition-colors leading-snug">
        {displayName}
      </a>
      {highlight && (
        <p class="mt-1 text-xs text-slate-500 line-clamp-2">{highlight}</p>
      )}
    </div>

    <!-- Spec badges -->
    <div class="flex flex-wrap gap-1.5">
      {airflow && (
        <span class="spec-badge">
          <svg class="h-3 w-3 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
          </svg>
          {airflow}
        </span>
      )}
      {coverage && (
        <span class="spec-badge">
          <svg class="h-3 w-3 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5v-4m0 4h-4m4 0l-5-5"/>
          </svg>
          {coverage}
        </span>
      )}
    </div>

    <!-- Price + CTA -->
    <div class="mt-auto flex items-center justify-between gap-2 pt-2 border-t border-slate-50">
      <div class="text-sm font-medium text-slate-900">
        {priceHkd !== null
          ? `${t(locale, 'range.price.from')}${formatHkd(priceHkd).replace('HK$', '')}`
          : <span class="text-slate-400 text-xs font-normal">{t(locale, 'range.price.enquire')}</span>
        }
      </div>
      <a
        href={waHref}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-xs px-4 py-2 shrink-0"
        aria-label={`WhatsApp enquiry for ${displayName}`}
      >
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        {t(locale, 'range.cta')}
      </a>
    </div>
  </div>
</article>
