---
import { t, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const features = [
  {
    titleKey: 'why.f1.title' as const,
    descKey:  'why.f1.desc'  as const,
    // Thermometer / temperature drop icon
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/>`,
    accent: true,
  },
  {
    titleKey: 'why.f2.title' as const,
    descKey:  'why.f2.desc'  as const,
    // Shield check icon
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>`,
    accent: false,
  },
  {
    titleKey: 'why.f3.title' as const,
    descKey:  'why.f3.desc'  as const,
    // Wifi / signal icon
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 0 1 1.06 0Z"/>`,
    accent: false,
  },
  {
    titleKey: 'why.f4.title' as const,
    descKey:  'why.f4.desc'  as const,
    // Sound / quiet waves icon
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75 19.5 12m0 0 2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25m-10.5-6 4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z"/>`,
    accent: false,
  },
  {
    titleKey: 'why.f5.title' as const,
    descKey:  'why.f5.desc'  as const,
    // Maximize / coverage area icon
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>`,
    accent: true,
  },
  {
    titleKey: 'why.f6.title' as const,
    descKey:  'why.f6.desc'  as const,
    // Leaf / eco icon
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>`,
    accent: false,
  },
] as const;
---

<div class="reveal-stagger grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {features.map(({ titleKey, descKey, icon, accent }) => (
    <div class={`stagger-item rounded-2xl p-6 transition-shadow hover:shadow-sm ${
      accent
        ? 'bg-sky-500 text-white'
        : 'bg-white border border-slate-100'
    }`}>
      <div class={`mb-4 flex h-11 w-11 items-center justify-center rounded-xl ${
        accent ? 'bg-white/20' : 'bg-sky-50'
      }`}>
        <svg
          class={`h-6 w-6 ${accent ? 'text-white' : 'text-sky-500'}`}
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <Fragment set:html={icon} />
        </svg>
      </div>
      <h3 class={`mb-2 text-sm font-semibold ${accent ? 'text-white' : 'text-slate-900'}`}>
        {t(locale, titleKey)}
      </h3>
      <p class={`text-sm leading-relaxed ${accent ? 'text-sky-100' : 'text-slate-500'}`}>
        {t(locale, descKey)}
      </p>
    </div>
  ))}
</div>
