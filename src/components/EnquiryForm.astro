---
import { t, type Locale } from '../i18n/index';
import { products, contact } from '../data/products';

interface Props {
  locale: Locale;
  preselect?: string;
}
const { locale, preselect = '' } = Astro.props;
---

<form id="enquiry-form" class="space-y-5" novalidate>

  <div>
    <label for="eq-name" class="block mb-1.5 text-sm font-medium text-slate-700">
      {t(locale, 'enquiry.name')}
    </label>
    <input
      id="eq-name"
      name="name"
      type="text"
      autocomplete="name"
      placeholder={t(locale, 'enquiry.name.ph')}
      required
      class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-sky-400 focus:outline-none focus:ring-2 focus:ring-sky-100 transition"
    />
  </div>

  <div>
    <label for="eq-product" class="block mb-1.5 text-sm font-medium text-slate-700">
      {t(locale, 'enquiry.product')}
    </label>
    <select
      id="eq-product"
      name="product"
      required
      class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-900 focus:border-sky-400 focus:outline-none focus:ring-2 focus:ring-sky-100 transition bg-white appearance-none"
    >
      <option value="">{t(locale, 'enquiry.product.ph')}</option>
      {products.map((p) => (
        <option value={p.name[locale]} selected={p.id === preselect}>
          {p.name[locale]}
        </option>
      ))}
      <option value={locale === 'zh' ? '一般查詢' : 'General enquiry'}>
        {locale === 'zh' ? '一般查詢' : 'General enquiry'}
      </option>
    </select>
  </div>

  <div>
    <label for="eq-message" class="block mb-1.5 text-sm font-medium text-slate-700">
      {t(locale, 'enquiry.message')}
    </label>
    <textarea
      id="eq-message"
      name="message"
      rows="4"
      placeholder={t(locale, 'enquiry.message.ph')}
      class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-sky-400 focus:outline-none focus:ring-2 focus:ring-sky-100 transition resize-none"
    ></textarea>
  </div>

  <button
    type="submit"
    class="btn-primary w-full justify-center py-3.5"
  >
    <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
    {t(locale, 'enquiry.submit')}
  </button>
</form>

<script define:vars={{ waNumber: contact.whatsapp, locale }}>
  const form = document.getElementById('enquiry-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = (data.get('name') || '').toString().trim();
    const product = (data.get('product') || '').toString().trim();
    const message = (data.get('message') || '').toString().trim();

    if (!name || !product) {
      const nameInput = form.querySelector('[name="name"]');
      const productInput = form.querySelector('[name="product"]');
      if (!name) nameInput?.classList.add('border-red-400');
      if (!product) productInput?.classList.add('border-red-400');
      return;
    }

    const parts = locale === 'zh'
      ? [`你好 AirMax，我係 ${name}。`, `我想查詢：${product}。`, message && `留言：${message}`]
      : [`Hi AirMax, I'm ${name}.`, `I'm interested in: ${product}.`, message && `Message: ${message}`];

    const text = parts.filter(Boolean).join('\n');
    window.open(`https://wa.me/${waNumber}?text=${encodeURIComponent(text)}`, '_blank', 'noopener,noreferrer');
  });

  // Clear red border on change
  form?.querySelectorAll('input, select').forEach((el) => {
    el.addEventListener('input', () => el.classList.remove('border-red-400'));
  });
</script>
